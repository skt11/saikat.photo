---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About" description="Saikat Adhikari is a Stockholm-based photographer and software engineer.">
	<section class="container about stack">
		<h1>About</h1>
		<p>
			Saikat Adhikari is a Stockholm-based photographer and software engineer
			exploring cinematic light, urban solitude, memory, and quiet unease.
		</p>
	</section>
</Layout>

<style>
	.about {
		padding-block: var(--space-5);
		max-width: var(--measure);
	}
</style>

---
import Layout from "../layouts/Layout.astro";

const instagramHandle = "the_rightful_shore";
---

<Layout title="Contact" description="Get in touch.">
	<section class="container contact">
		<div class="label">Contact</div>
		<ul class="links">
			<li>
				<a href={`https://instagram.com/${instagramHandle}`} rel="me noopener" target="_blank">
					Instagram <span class="muted">↗</span>
				</a>
			</li>
			<li>
				<a href="https://github.com/skt11" rel="me noopener" target="_blank">
					GitHub <span class="muted">↗</span>
				</a>
			</li>
		</ul>
	</section>
</Layout>

<style>
	.contact {
		padding-block: var(--space-5) var(--space-6);
		max-width: var(--measure);
	}

	.label {
		margin-bottom: var(--space-3);
	}

	.links {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}

	.links a {
		font-size: 1.25rem;
		letter-spacing: -0.01em;
	}
</style>

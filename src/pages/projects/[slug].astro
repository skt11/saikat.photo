---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import PhotoFigure from "../../components/PhotoFigure.astro";

export async function getStaticPaths() {
	const projects = await getCollection("projects", ({ data }) => data.published);
	return projects.map((project) => ({
		params: { slug: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const { title, year, location, description, cover, photos } = project.data;
---

<Layout title={title} description={description}>
	<article class="project">
		<header class="project-header container">
			<h1>{title}</h1>
			<p class="muted meta">{year} · {location}</p>
			<p class="description">{description}</p>
		</header>

		<div class="hero">
			<Image
				src={cover}
				alt={`${title} — cover`}
				widths={[1200, 1800, 2400, 3000]}
				sizes="100vw"
				loading="eager"
				fetchpriority="high"
			/>
		</div>

		<div class="photos container">
			{photos.map((photo) => (
				<PhotoFigure src={photo.src} alt={photo.alt} caption={photo.caption} />
			))}
		</div>
	</article>
</Layout>

<style>
	.project-header {
		padding-block: var(--space-5) var(--space-4);
		max-width: var(--measure);
	}

	.project-header h1 {
		margin-bottom: var(--space-1);
	}

	.meta {
		margin: 0 0 var(--space-3);
		font-size: 0.95rem;
	}

	.description {
		margin: 0;
	}

	.hero {
		margin-block: var(--space-4) var(--space-5);
	}

	.hero :global(img) {
		width: 100%;
		height: auto;
		max-height: 85dvh;
		object-fit: cover;
	}

	.photos {
		display: flex;
		flex-direction: column;
		gap: var(--space-5);
		max-width: 1100px;
	}
</style>

---
import { Image, getImage } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Photo {
	src: ImageMetadata;
	alt: string;
	caption?: string;
}

interface Props {
	photos: Photo[];
}

const { photos } = Astro.props;

const fullImages = await Promise.all(
	photos.map((p) => getImage({ src: p.src, width: 2400, format: "webp" })),
);

const lightboxData = photos.map((p, i) => ({
	alt: p.alt,
	caption: p.caption ?? "",
	full: fullImages[i].src,
}));
---

<section class="gallery" data-gallery data-mode="grid">
	<div class="toolbar">
		<div class="modes" role="group" aria-label="Layout">
			<button type="button" class="opt" data-mode="grid" aria-label="Grid layout">Grid</button>
			<button type="button" class="opt" data-mode="list" aria-label="List layout">List</button>
			<span class="thumb" aria-hidden="true"></span>
		</div>
	</div>

	<div class="items">
		{photos.map((p, i) => (
			<button
				type="button"
				class="tile"
				data-index={i}
				aria-label={`Open photo ${i + 1}: ${p.alt}`}
			>
				<Image
					src={p.src}
					alt={p.alt}
					widths={[400, 600, 900, 1200]}
					sizes="(min-width: 900px) 30vw, (min-width: 600px) 45vw, 100vw"
					loading="lazy"
				/>
			</button>
		))}
	</div>

	<dialog class="lightbox" aria-label="Image viewer">
		<button type="button" class="lb-btn lb-close" aria-label="Close (Esc)">
			<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
				<path d="M6 6L18 18" /><path d="M6 18L18 6" />
			</svg>
		</button>
		<button type="button" class="lb-btn lb-prev" aria-label="Previous (←)">
			<svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
				<path d="M15 6L9 12L15 18" />
			</svg>
		</button>
		<button type="button" class="lb-btn lb-next" aria-label="Next (→)">
			<svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
				<path d="M9 6L15 12L9 18" />
			</svg>
		</button>
		<div class="lb-stage">
			<img class="lb-image" alt="" />
		</div>
		<div class="lb-meta">
			<span class="lb-counter"></span>
			<span class="lb-caption"></span>
		</div>
	</dialog>
</section>

<script is:inline data-astro-rerun define:vars={{ lightboxData }}>
	(() => {
		const gallery = document.currentScript.previousElementSibling;
		if (!gallery) return;
		const lb = gallery.querySelector(".lightbox");
		const lbImg = lb.querySelector(".lb-image");
		const lbCounter = lb.querySelector(".lb-counter");
		const lbCaption = lb.querySelector(".lb-caption");
		const tiles = gallery.querySelectorAll(".tile");
		const modeBtns = gallery.querySelectorAll(".modes .opt");

		let current = 0;
		let lastFocus = null;

		const STORAGE_KEY = "saikat.photo:gallery-mode";

		const setMode = (mode) => {
			gallery.dataset.mode = mode;
			modeBtns.forEach((b) => b.classList.toggle("active", b.dataset.mode === mode));
			try { localStorage.setItem(STORAGE_KEY, mode); } catch {}
		};

		try {
			const saved = localStorage.getItem(STORAGE_KEY);
			setMode(saved === "list" ? "list" : "grid");
		} catch { setMode("grid"); }

		modeBtns.forEach((b) => b.addEventListener("click", () => setMode(b.dataset.mode)));

		const preload = (i) => {
			if (i < 0 || i >= lightboxData.length) return;
			const img = new Image();
			img.src = lightboxData[i].full;
		};

		const render = () => {
			const p = lightboxData[current];
			lbImg.classList.add("is-loading");
			lbImg.src = p.full;
			lbImg.alt = p.alt;
			lbCounter.textContent = `${String(current + 1).padStart(2, "0")} / ${String(lightboxData.length).padStart(2, "0")}`;
			lbCaption.textContent = p.caption;
		};

		lbImg.addEventListener("load", () => lbImg.classList.remove("is-loading"));

		const open = (i) => {
			current = i;
			lastFocus = document.activeElement;
			render();
			if (typeof lb.showModal === "function") lb.showModal();
			else lb.setAttribute("open", "");
			document.documentElement.style.overflow = "hidden";
			preload(current + 1);
			preload(current - 1);
		};

		const close = () => {
			if (typeof lb.close === "function") lb.close();
			else lb.removeAttribute("open");
			document.documentElement.style.overflow = "";
			if (lastFocus && typeof lastFocus.focus === "function") lastFocus.focus();
		};

		const nav = (delta) => {
			current = (current + delta + lightboxData.length) % lightboxData.length;
			render();
			preload(current + delta);
		};

		tiles.forEach((t) =>
			t.addEventListener("click", () => open(Number(t.dataset.index))),
		);
		lb.querySelector(".lb-close").addEventListener("click", close);
		lb.querySelector(".lb-prev").addEventListener("click", () => nav(-1));
		lb.querySelector(".lb-next").addEventListener("click", () => nav(1));

		lb.addEventListener("click", (e) => {
			if (e.target === lb || e.target.classList.contains("lb-stage")) close();
		});

		// document-level listeners — clean up old ones across page transitions
		if (window.__saikatPhotoLbAbort) window.__saikatPhotoLbAbort.abort();
		const abort = new AbortController();
		window.__saikatPhotoLbAbort = abort;

		document.addEventListener("keydown", (e) => {
			if (!lb.hasAttribute("open")) return;
			if (e.key === "Escape") { e.preventDefault(); close(); }
			else if (e.key === "ArrowRight") nav(1);
			else if (e.key === "ArrowLeft") nav(-1);
		}, { signal: abort.signal });

		let touchStartX = 0;
		let touchStartY = 0;
		lb.addEventListener("touchstart", (e) => {
			touchStartX = e.touches[0].clientX;
			touchStartY = e.touches[0].clientY;
		}, { passive: true });
		lb.addEventListener("touchend", (e) => {
			const dx = e.changedTouches[0].clientX - touchStartX;
			const dy = e.changedTouches[0].clientY - touchStartY;
			if (Math.abs(dx) > 60 && Math.abs(dx) > Math.abs(dy)) nav(dx < 0 ? 1 : -1);
		}, { passive: true });

		// tile reveal — IntersectionObserver fade-up
		if (window.__saikatPhotoIO) window.__saikatPhotoIO.disconnect();
		const io = new IntersectionObserver((entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add("in");
					io.unobserve(entry.target);
				}
			});
		}, { rootMargin: "80px 0px", threshold: 0.05 });
		window.__saikatPhotoIO = io;
		tiles.forEach((t) => io.observe(t));
	})();
</script>

<style>
	.gallery {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
	}

	.toolbar {
		display: flex;
		justify-content: flex-end;
		align-items: center;
		padding-bottom: var(--space-2);
		border-bottom: 1px solid var(--rule);
	}

	.modes {
		position: relative;
		display: inline-flex;
		border: 1px solid var(--rule);
		border-radius: 999px;
		padding: 3px;
	}

	.opt {
		position: relative;
		z-index: 1;
		background: none;
		border: 0;
		color: var(--muted);
		font: inherit;
		font-size: 0.7rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		padding: 0.45rem 1rem;
		border-radius: 999px;
		cursor: pointer;
		transition: color 240ms ease;
	}

	.opt:hover { color: var(--fg); }
	.opt.active { color: var(--fg); }

	.thumb {
		position: absolute;
		top: 3px;
		left: 3px;
		width: calc(50% - 3px);
		height: calc(100% - 6px);
		background: var(--rule);
		border-radius: 999px;
		transition: transform 280ms cubic-bezier(0.4, 0, 0.2, 1);
		pointer-events: none;
	}

	.gallery[data-mode="list"] .thumb {
		transform: translateX(100%);
	}

	.items {
		display: grid;
		gap: var(--space-2);
		grid-template-columns: 1fr;
	}

	@media (min-width: 600px) {
		.gallery[data-mode="grid"] .items { grid-template-columns: 1fr 1fr; }
	}

	@media (min-width: 900px) {
		.gallery[data-mode="grid"] .items { grid-template-columns: 1fr 1fr 1fr; }
	}

	.gallery[data-mode="list"] .items {
		grid-template-columns: 1fr;
		gap: var(--space-6);
		max-width: 1000px;
		margin-inline: auto;
	}

	.tile {
		background: none;
		border: 0;
		padding: 0;
		margin: 0;
		display: block;
		cursor: zoom-in;
		overflow: hidden;
		color: inherit;
		opacity: 0;
		transform: translateY(14px);
		transition: opacity 600ms ease, transform 600ms ease;
	}

	.tile.in {
		opacity: 1;
		transform: translateY(0);
	}

	.gallery[data-mode="grid"] .tile {
		aspect-ratio: 3 / 2;
		background: var(--rule);
	}

	.gallery[data-mode="grid"] .tile :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 800ms ease, opacity 300ms ease;
	}

	.gallery[data-mode="grid"] .tile:hover :global(img) {
		transform: scale(1.045);
		opacity: 0.92;
	}

	.gallery[data-mode="list"] .tile {
		aspect-ratio: auto;
	}

	.gallery[data-mode="list"] .tile :global(img) {
		width: 100%;
		height: auto;
	}

	.lightbox {
		border: 0;
		padding: 0;
		margin: 0;
		width: 100vw;
		height: 100dvh;
		max-width: 100vw;
		max-height: 100dvh;
		background: var(--bg);
		color: var(--fg);
		overflow: hidden;
		opacity: 0;
		transition: opacity 220ms ease, display 220ms allow-discrete;
	}

	.lightbox[open] {
		opacity: 1;
	}

	@starting-style {
		.lightbox[open] {
			opacity: 0;
		}
	}

	.lightbox::backdrop {
		background: rgba(0, 0, 0, 0.96);
	}

	.lb-stage {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: var(--space-3);
	}

	.lb-image {
		max-width: min(94vw, 1800px);
		max-height: 84dvh;
		width: auto;
		height: auto;
		object-fit: contain;
		transition: opacity 220ms ease;
	}

	.lb-image.is-loading { opacity: 0.25; }

	.lb-btn {
		position: absolute;
		background: transparent;
		border: 0;
		color: var(--fg);
		cursor: pointer;
		padding: var(--space-2);
		opacity: 0.45;
		transition: opacity 180ms ease;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
	}

	.lb-btn:hover { opacity: 1; }

	.lb-close {
		top: var(--space-2);
		right: var(--space-2);
	}

	.lb-prev,
	.lb-next {
		top: 50%;
		transform: translateY(-50%);
	}

	.lb-prev { left: var(--space-1); }
	.lb-next { right: var(--space-1); }

	.lb-meta {
		position: absolute;
		bottom: var(--space-3);
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		gap: var(--space-3);
		font-size: 0.7rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--muted);
		white-space: nowrap;
		max-width: 90vw;
		overflow: hidden;
		text-overflow: ellipsis;
		font-variant-numeric: tabular-nums;
	}

	.lb-caption {
		text-transform: none;
		letter-spacing: 0.04em;
		color: var(--muted);
	}

	@media (max-width: 600px) {
		.lb-prev svg, .lb-next svg { width: 26px; height: 26px; }
		.lb-meta { font-size: 0.66rem; gap: var(--space-2); }
	}
</style>

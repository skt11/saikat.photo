---
const path = Astro.url.pathname;
const links = [
	{ href: "/projects", label: "Projects" },
	{ href: "/contact", label: "Contact" },
];
const isActive = (href: string) => path === href || path.startsWith(href + "/");
---

<header class="site-header" transition:persist>
	<div class="container row">
		<a href="/" class="brand">Saikat Adhikari</a>
		<nav>
			{links.map((l) => (
				<a href={l.href} class:list={["nav-link", { active: isActive(l.href) }]}>{l.label}</a>
			))}
		</nav>
	</div>
</header>

<style>
	.site-header {
		padding-block: var(--space-3);
		background: var(--bg);
	}

	.row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-4);
	}

	.brand {
		font-family: var(--font-serif);
		font-optical-sizing: auto;
		font-size: 1.1rem;
		letter-spacing: -0.005em;
		color: var(--fg);
	}

	nav {
		display: flex;
		gap: var(--space-3);
	}

	.nav-link {
		font-size: 0.78rem;
		letter-spacing: 0.1em;
		color: var(--muted);
		text-transform: uppercase;
	}

	.nav-link.active,
	.nav-link:hover {
		color: var(--fg);
	}

	@media (max-width: 480px) {
		.row {
			gap: var(--space-2);
		}

		.brand {
			font-size: 1rem;
		}

		nav {
			gap: var(--space-2);
		}

		.nav-link {
			font-size: 0.72rem;
		}
	}
</style>

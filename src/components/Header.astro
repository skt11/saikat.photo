---
const links = [
	{ href: "/projects", label: "Projects" },
	{ href: "/about", label: "About" },
	{ href: "/contact", label: "Contact" },
];
---

<header class="site-header">
	<div class="container header-inner">
		<a href="/" class="brand">Saikat Adhikari</a>
		<nav>
			<ul>
				{links.map((l) => (
					<li><a href={l.href}>{l.label}</a></li>
				))}
			</ul>
		</nav>
	</div>
</header>

<style>
	.site-header {
		padding-block: var(--space-3);
		border-bottom: 1px solid var(--rule);
	}

	.header-inner {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: var(--space-3);
	}

	.brand {
		font-family: var(--font-serif);
		font-size: 1.1rem;
		letter-spacing: 0.01em;
		border-bottom: none;
	}

	nav ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		gap: var(--space-3);
	}

	nav a {
		border-bottom: none;
		color: var(--muted);
		font-size: 0.9rem;
	}

	nav a:hover {
		color: var(--fg);
		opacity: 1;
	}
</style>

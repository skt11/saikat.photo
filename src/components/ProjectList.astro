---
import { getImage } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
	projects: CollectionEntry<"projects">[];
}

const { projects } = Astro.props;

const previews = await Promise.all(
	projects.map(async (p) => {
		const img = await getImage({ src: p.data.cover, width: 600, format: "webp" });
		return img.src;
	}),
);
---

<ol class="list">
	{projects.map((p, i) => (
		<li>
			<a href={`/projects/${p.id}`} class="row" data-preview={previews[i]}>
				<span
					class="title"
					transition:name={`title-${p.id}`}
				>{p.data.title}</span>
				<span class="year">{p.data.year}</span>
			</a>
		</li>
	))}
</ol>

<div class="peek" data-peek aria-hidden="true">
	<img data-peek-img alt="" />
</div>

<script is:inline data-astro-rerun>
	(() => {
		const peek = document.querySelector("[data-peek]");
		const peekImg = document.querySelector("[data-peek-img]");
		const rows = document.querySelectorAll(".row[data-preview]");
		if (!peek || !peekImg || !rows.length) return;

		const isTouch = matchMedia("(hover: none)").matches;
		if (isTouch) return;

		let rafId = null;
		let targetX = 0;
		let targetY = 0;
		let currentX = 0;
		let currentY = 0;

		const animate = () => {
			currentX += (targetX - currentX) * 0.18;
			currentY += (targetY - currentY) * 0.18;
			peek.style.transform = `translate(${currentX}px, ${currentY}px)`;
			rafId = requestAnimationFrame(animate);
		};

		rows.forEach((row) => {
			row.addEventListener("mouseenter", () => {
				peekImg.src = row.dataset.preview;
				peek.classList.add("visible");
				if (!rafId) animate();
			});
			row.addEventListener("mouseleave", () => {
				peek.classList.remove("visible");
			});
		});

		document.addEventListener("mousemove", (e) => {
			targetX = e.clientX + 24;
			targetY = e.clientY - 110;
		});
	})();
</script>

<style>
	.list {
		list-style: none;
		margin: 0;
		padding: 0;
		border-top: 1px solid var(--rule);
	}

	.list li {
		border-bottom: 1px solid var(--rule);
	}

	.row {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: var(--space-3);
		padding-block: var(--space-4);
		color: var(--fg);
	}

	.title {
		font-family: var(--font-serif);
		font-optical-sizing: auto;
		font-weight: 400;
		font-size: clamp(1.75rem, 4.5vw, 3.25rem);
		letter-spacing: -0.02em;
		line-height: 1;
		transition: opacity 240ms ease, letter-spacing 240ms ease;
	}

	.year {
		color: var(--muted);
		font-size: 0.78rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		font-variant-numeric: tabular-nums;
	}

	.row:hover .title {
		opacity: 0.55;
	}

	.peek {
		position: fixed;
		top: 0;
		left: 0;
		width: 240px;
		height: 160px;
		pointer-events: none;
		opacity: 0;
		transform: translate(-9999px, -9999px);
		transition: opacity 240ms ease;
		z-index: 5;
		overflow: hidden;
		border-radius: 2px;
	}

	.peek.visible {
		opacity: 1;
	}

	.peek img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	@media (hover: none) {
		.peek {
			display: none;
		}
	}
</style>

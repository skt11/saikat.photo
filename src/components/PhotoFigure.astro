---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
	src: ImageMetadata;
	alt: string;
	caption?: string;
	priority?: boolean;
}

const { src, alt, caption, priority = false } = Astro.props;
---

<figure class="photo">
	<Image
		src={src}
		alt={alt}
		widths={[800, 1200, 1800, 2400]}
		sizes="(min-width: 1200px) 1100px, 100vw"
		loading={priority ? "eager" : "lazy"}
		{...(priority ? { fetchpriority: "high" } : {})}
	/>
	{caption && <figcaption class="muted">{caption}</figcaption>}
</figure>

<style>
	.photo {
		margin: 0;
	}

	.photo :global(img) {
		width: 100%;
		height: auto;
	}

	figcaption {
		margin-top: var(--space-1);
		font-size: 0.85rem;
	}
</style>

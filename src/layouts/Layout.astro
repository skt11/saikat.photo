---
import "@fontsource-variable/fraunces/opsz.css";
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
}

const {
	title = "Saikat Adhikari",
	description = "Photography, moving image, visual studies. Stockholm.",
	ogImage,
} = Astro.props;

const fullTitle = title === "Saikat Adhikari" ? title : `${title} — Saikat Adhikari`;
const siteUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
const absOgImage = ogImage ? new URL(ogImage, Astro.site ?? Astro.url.origin).toString() : undefined;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<title>{fullTitle}</title>
		<meta name="description" content={description} />

		<link rel="canonical" href={siteUrl} />

		<meta property="og:type" content="website" />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={siteUrl} />
		{absOgImage && <meta property="og:image" content={absOgImage} />}
		<meta name="twitter:card" content={absOgImage ? "summary_large_image" : "summary"} />

		<ClientRouter />
	</head>
	<body>
		<Header />
		<main><slot /></main>
		<Footer />
	</body>
</html>
